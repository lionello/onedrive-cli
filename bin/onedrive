#!/usr/bin/env node
const Colors = require('colors/safe')
const Crypto = require('crypto')
const fetch = require('node-fetch')
const FS = require('fs/promises')
const Http = require('http')
const Https = require('https')
const Mime = require('mime')
const Moment = require('moment')
const Path = require('path')
const Readline = require('readline')
const Zlib = require('zlib')

// The $XDG_STATE_HOME directory contains state data that should persist between (application) restarts.
const TOKEN_PATH = Path.join(
    process.env.XDG_STATE_HOME || require('os').homedir(),
    '.onedrive-cli-token'
)
const API_BASE_URL = 'https://api.onedrive.com/v1.0'

const httpsAgent = new Https.Agent({ keepAlive: true })

function makeAbsolute(url) {
    return url.startsWith('https://') ? url : API_BASE_URL + url
}

async function checkResponse(response) {
    debugPrint(response.status, response.statusText)
    const location = response.headers.get('location')
    if (response.status === 202 && location) {
        const locationURL = new URL(location, response.url)
        console.warn(Colors.yellow('GET'), locationURL.href)
        response = await fetch(locationURL)
    }
    if (!response.ok) {
        const contentType = response.headers.get('content-type') || ''
        if (!contentType.startsWith('application/json')) {
            const msg = await response.text()
            throw Object.assign(Error(msg), { statusCode: response.status })
        }
        const json = await response.json()
        const error = json.error || {}
        // Throw a real Error (not the bare API object) so the message is
        // readable everywhere -- otherwise callers that stringify it, like the
        // MCP layer, surface a useless "[object Object]". Spread the API error
        // before the computed fields so an empty/missing error.message can't
        // clobber the fallback. Carry statusCode so callers can detect auth
        // failures (401) and permission errors (403).
        throw Object.assign(
            new Error(
                error.message ||
                    error.code ||
                    response.statusText ||
                    'Request failed'
            ),
            error,
            { statusCode: response.status }
        )
    }
    return response
}

function sha1hash(data) {
    const sha1 = Crypto.createHash('sha1').update(data).digest('hex')
    return sha1
}

function padLeft(str, len) {
    return String('                ' + str).slice(-len)
}

function padRight(str, len) {
    return str + ' '.repeat(len - str.length)
}

function debugPrint(...data) {
    if (process.stdout.isTTY && process.env.NODE_ENV === 'development') {
        console.debug(...data)
    }
}

function print(data) {
    // FIXME: handle false return value by hooking the drain event
    process.stdout.write(data)
}

function humanize(num) {
    const units = ['', 'Ki', 'Mi', 'Gi', 'Ti', 'Pi']
    let div = 0
    for (;;) {
        const str = Math.round(num / Math.pow(1024, div))
        if (str <= 9999) {
            return str + units[div]
        }
        ++div
    }
}

function prettyPrint(num) {
    return padLeft(humanize(num), 6)
}

// Read the token fresh from disk on every request -- a ~1KB read next to each
// HTTPS round-trip is negligible, and it means a re-login (even from another
// process, e.g. the CLI) is picked up immediately by the long-running MCP
// server instead of being masked by a stale in-memory copy. Trim so a trailing
// newline in the file can't corrupt the Authorization header.
async function lazyToken() {
    return (await FS.readFile(TOKEN_PATH)).toString().trim()
}

async function saveToken(token) {
    await FS.writeFile(TOKEN_PATH, token.trim())
    return TOKEN_PATH
}

async function call(url, method, body, headers = {}) {
    const token = await lazyToken()
    const options = {
        agent: httpsAgent,
        body: body,
        method: method || 'GET',
        headers: {
            Authorization: 'bearer ' + token,
            'Content-Type': 'application/octet-stream',
            Accept: 'application/json',
            ...headers,
        },
    }
    if (process.stdout.isTTY) {
        console.warn(Colors.yellow(options.method), decodeURIComponent(url))
    }

    if (body instanceof Buffer) {
        options.body = Zlib.gzipSync(body)
        options.headers['Content-Encoding'] = 'gzip'
    } else if (typeof body === 'object') {
        options.body = JSON.stringify(body)
        options.headers['Content-Type'] = 'application/json'
    }

    const resp = await fetch(makeAbsolute(url), options)
    const data = await checkResponse(resp)
    return data.json()
}

async function getContent(url) {
    if (process.stdout.isTTY) {
        console.warn(Colors.yellow('GET'), decodeURIComponent(url))
    }

    const token = await lazyToken()
    const resp = await fetch(makeAbsolute(url), {
        agent: httpsAgent,
        headers: {
            Authorization: 'bearer ' + token,
        },
    })
    const data = await checkResponse(resp)
    return data.buffer()
}

// Download only [offset, offset+length) of a file via an HTTP Range request,
// so large files never come down whole. Returns the bytes plus the total size
// parsed from Content-Range (undefined if the server didn't report it).
async function getRange(url, offset, length) {
    const token = await lazyToken()
    const resp = await fetch(makeAbsolute(url), {
        agent: httpsAgent,
        // Byte ranges are only meaningful on the identity representation, so
        // don't let node-fetch negotiate/inflate gzip (partial gzip won't
        // decode, and offsets wouldn't line up with the file's bytes).
        compress: false,
        headers: {
            Authorization: 'bearer ' + token,
            Range: 'bytes=' + offset + '-' + (offset + length - 1),
        },
    })
    const total = (cr => {
        const m = cr && /\/\s*(\d+)\s*$/.exec(cr)
        return m ? Number(m[1]) : undefined
    })(resp.headers.get('content-range'))
    // Range past EOF: report an empty tail instead of throwing.
    if (resp.status === 416) {
        return { buffer: Buffer.alloc(0), total }
    }
    await checkResponse(resp)
    let buffer = await resp.buffer()
    if (resp.status === 200) {
        // Server ignored the Range and sent the whole file; slice locally so
        // the result is still correct (no bandwidth win in this fallback).
        return {
            buffer: buffer.subarray(offset, offset + length),
            total: buffer.length,
        }
    }
    return { buffer, total }
}

function sanitize(remote) {
    // Escape all characters except the path delimiter '/'
    return (
        '/drive/root:/' +
        encodeURIComponent(remote.replace(/^:?\/?\.?/, '')).replace(
            /%2f/gi,
            '/'
        ) +
        ':'
    )
}

function absolute(info) {
    const parent = info.parentReference.path.replace(/^\/drive\/root/, '')
    return decodeURIComponent(parent) + '/' + info.name
}

/*
Filesystem         Size   Used  Avail Capacity Deleted
dc1e3335a482dc20 1214Gi  164Gi 1050Gi      14%   780Mi
*/
async function df() {
    const result = await call('/drives')
    console.log(
        Colors.bold(
            'Drive              Size   Used  Avail Capacity Deleted Status'
        )
    )
    for (const drive of result.value) {
        const capacity =
            Math.round((drive.quota.used * 100) / drive.quota.total) + '% '
        console.log(
            padRight(drive.id, 16),
            prettyPrint(drive.quota.total),
            prettyPrint(drive.quota.used),
            prettyPrint(drive.quota.remaining),
            padLeft(capacity, 9),
            prettyPrint(drive.quota.deleted),
            (drive.status && drive.status.state) || ''
        )
    }
}

async function ls_paged(total, cont) {
    if (cont === undefined) {
        return total
    }

    const result = await call(cont)
    const now = Moment()
    const threshold = 1000 * 60 * 60 * 24 * 180 //180days
    for (const f of result.value) {
        const m = Moment(f.lastModifiedDateTime)
        const d = 'folder' in f
        let mod = d ? 'drwx' : '-rw-'
        if ('shared' in f) {
            if (
                'effectiveRoles' in f.shared &&
                f.shared.effectiveRoles.length === 1 &&
                f.shared.effectiveRoles[0] === 'read'
            ) {
                mod += d ? 'r-x' : 'r--'
                if (f.shared.scope === 'anonymous') {
                    mod += d ? 'r-x' : 'r--'
                } else {
                    mod += '---'
                }
            } else {
                mod += d ? 'rwx' : 'rw-'
                if (f.shared.scope === 'anonymous') {
                    mod += d ? 'rwx' : 'rw-'
                } else {
                    mod += '---'
                }
            }
        } else {
            mod += '------'
        }
        const count = d ? f.folder.childCount : 1
        total += count
        console.log(
            mod,
            padLeft(count, 3),
            f.createdBy.user.displayName,
            padLeft(f.size, 10),
            m.format(
                Math.abs(now - m) < threshold ? 'MMM DD HH:mm' : 'MMM DD  YYYY'
            ),
            d ? Colors.bold(Colors.blue(f.name)) + '/' : f.name
        )
    }
    return ls_paged(total, result['@odata.nextLink'])
}

async function ls(folders) {
    if (folders.length === 0) {
        folders = ['']
    }

    //console.log(Colors.bold('Permission Cnt Owner            Size     Date         Name'))
    let result = 0
    for (const folder of folders) {
        result = await ls_paged(result, sanitize(folder) + '/children')
    }
    return 'total ' + result
}

const MOVE = 'move'
const COPY = 'copy'

/*
PUT /drive/root:/{parent-path}/{filename}:/content
@name.conflictBehavior   fail, replace (def), or rename.
*/
async function upload(op, from, target) {
    if (from.endsWith('/')) {
        throw Error('Invalid source name')
    }
    if (target.endsWith('/')) {
        target = target + Path.basename(from)
    }
    target = sanitize(target)
    const mime = Mime.lookup(from)
    const data = await FS.readFile(from)
    // TODO: skip upload if SHA1 is the same
    const result = await call(
        target + '/content?@name.conflictBehavior=fail',
        'PUT',
        data,
        { 'Content-Type': mime }
    )
    const sha1 = sha1hash(data).toUpperCase()
    if (sha1 !== result.file.hashes.sha1Hash) {
        throw Error('sha1Hash mismatch: ' + target)
    }
    try {
        if (op === MOVE) {
            console.log(from, '=>', target, result.id)
            await FS.unlink(from)
        } else {
            console.log(from, '->', target, result.id)
        }
    } catch (err) {
        if (err.statusCode === 404) {
            return console.error(
                'Skipped. Uploads larger than 100MiB are not yet supported.'
            )
        }
        throw err
    }
}

/*
POST /drive/items/{parent-item}/children
Content-Type: application/json
Prefer: respond-async

{
  "@content.sourceUrl": "http://wscont2.apps.microsoft.com/winstore/1x/e33e38d9-d138-42a1-b252-27da1924ca87/Screenshot.225037.100000.jpg",
  "name": "halo-screenshot.jpg",
  "file": { }
}
*/
async function wget(args) {
    if (args.length !== 2) {
        console.error('usage: wget url target')
    } else {
        let target = args.pop()
        const from = args[0].startsWith('http') ? args[0] : 'http://' + args[0]
        const data = {
            '@content.sourceUrl': from,
            name: Path.basename(target),
            file: {},
        }
        if (data.name === '' || target.endsWith('/')) {
            throw Error('Invalid target name')
        }
        let path = Path.dirname(target + 'hack')
        target = sanitize(target)
        path = sanitize(path)
        await call(path + '/children', 'POST', data, {
            Prefer: 'respond-async',
        })
        console.log(from, '-->', target)
    }
}

/*
GET /drive/root:/{path and filename}:/content
*/
async function download(op, from, target) {
    if (from.endsWith('/')) {
        throw Error('Invalid source name')
    }
    if (target === undefined || target === '.' || target === '') {
        target = './'
    }
    if (target.endsWith('/')) {
        target = target + Path.basename(from)
    }
    const remote = sanitize(from)
    // TODO: avoid download if the SHA1 is the same
    const data = await getContent(remote + '/content')
    await FS.writeFile(target, data)
    if (op === MOVE) {
        console.log(from, '=>', target)
        return rmItem(from)
    } else {
        console.log(from, '->', target)
    }
}

/*
PATCH /me/drive/items/{item-id}
Content-type: application/json

{
  "parentReference": {
    "id": "{new-parent-folder-id}"
  },
  "name": "new-item-name.txt"
}
*/
function moveItem(item, path, name) {
    const remote = sanitize(item)
    const data = {
        name: name,
        parentReference: {
            path: sanitize(path), // FIXME: double escapes
        },
    }
    return call(remote, 'PATCH', data)
}

async function rename(from, target) {
    if (from.endsWith('/')) {
        throw Error('Invalid source name')
    }
    if (target.endsWith('/')) {
        target = target + Path.basename(from)
    }
    const parent = Path.dirname(target)
    const name = Path.basename(target)
    await moveItem(from, parent, name)
    console.log(`renamed '${from}' -> '${target}'`)
}

async function cp_mv(op, args, target) {
    if (args.length === 0) {
        return
    }

    if (args.length > 1 && !target.endsWith('/')) {
        throw Error('Target is not a directory')
    }

    if (args[0].startsWith('./') && target.startsWith('./')) {
        throw Error(`Local ${op} is not implemented.`)
    }

    if (args[0].startsWith(':/') && target.startsWith(':/')) {
        if (op !== MOVE) {
            throw Error(`Remote ${op} is not implemented.`)
        }
        // from onedrive to onedrive
        for (const cur of args) {
            await rename(cur, target)
        }
    } else if (args[0].startsWith('./') || target.startsWith(':/')) {
        // from local to onedrive
        for (const cur of args) {
            await upload(op, cur, target)
        }
    } else if (
        args[0].startsWith(':/') ||
        target.startsWith('./') ||
        target === '.'
    ) {
        // from onedrive to local
        for (const cur of args) {
            await download(op, cur, target)
        }
    } else {
        throw Error('Use ./ or :/ path prefix for local or remote paths.')
    }
}

async function cp_paged(cont, target) {
    if (cont === undefined) {
        return
    }
    const result = await call(cont)
    // TODO: copy by Item ID instead of path?
    const files = result.value.filter(info => !is_folder(info)).map(absolute)
    await cp_mv(COPY, files, target + '/')
    await cp_paged(result['@odata.nextLink'], target)
    // Recurse into subfolders
    const folders = result.value.filter(is_folder)
    for (const info of folders) {
        const folder = Path.join(target, info.name)
        await FS.mkdir(folder)
        await cp_paged(sanitize(absolute(info)) + '/children', folder)
    }
}

function is_folder(info) {
    return info.folder || (info.package && info.package.type === 'oneNote')
}

async function cp(args) {
    if (args.length < 2) {
        console.error('usage: cp [-R] source target')
        console.error('       cp [-R] source ... directory')
        console.error('       cp -t directory source ...')
    } else {
        if (args[0] === '-t') {
            const directory = args[1]
            return cp_mv(COPY, args.slice(2), directory)
        }

        const target = args.pop()
        if (args[0] !== '-R') {
            return cp_mv(COPY, args, target)
        }

        // Recursive copy
        for (const folder of args.slice(1)) {
            await cp_paged(sanitize(folder) + '/children', target)
        }
    }
}

/*
DELETE /drive/root:/{path}:
Returns 204 No Content on success.
Supports files and folders (recursive delete).
*/
async function rmItem(remote) {
    remote = sanitize(remote)
    const token = await lazyToken()
    const resp = await fetch(makeAbsolute(remote), {
        agent: httpsAgent,
        method: 'DELETE',
        headers: {
            Authorization: 'bearer ' + token,
        },
    })
    await checkResponse(resp)
    // 204 No Content on success — nothing to parse
}

async function rm(args) {
    if (args.length < 1) {
        console.error('usage: rm file ...')
    } else {
        for (const cur of args) {
            await rmItem(cur)
            console.log(`removed '${cur}'`)
        }
    }
}

function mv(args) {
    if (args.length < 2) {
        console.error('usage: mv source target')
        console.error('       mv source ... directory')
        console.error('       mv -t directory source ...')
    } else {
        if (args[0] === '-t') {
            const directory = args[1]
            return cp_mv(MOVE, args.slice(2), directory)
        }

        const target = args.pop()
        return cp_mv(MOVE, args, target)
    }
}

/*
POST /drive/items/{parent-item}/children
Content-Type: application/json

{
  "name": "New Folder",
  "file": { }
}
*/
function createFolder(parent, name) {
    const remote = sanitize(parent)
    const data = {
        name: name,
        folder: {},
    }
    return call(remote + '/children', 'POST', data)
}

async function mkdir1(dir) {
    const parent = Path.dirname(dir)
    const name = Path.basename(dir)
    const result = await createFolder(parent, name)
    console.log(`mkdir: created directory '${result.name}'`)
}

async function mkdir(args) {
    if (args.length < 1) {
        console.error('usage: mkdir directory_name ...')
    } else {
        for (const cur of args) {
            await mkdir1(cur)
        }
    }
}

async function cat1(remote) {
    remote = sanitize(remote)
    const data = await getContent(remote + '/content')
    print(data)
}

async function cat(args) {
    if (args.length < 1) {
        console.error('usage: cat file ...')
    } else {
        for (const cur of args) {
            await cat1(cur)
        }
    }
}

// How the user invoked us, so the landing page can echo a runnable command.
// Prefer a path relative to the cwd (keeps the folder, e.g. 'bin/onedrive')
// and fall back to the basename when we live outside the cwd (e.g. an
// installed 'onedrive' on the PATH).
function commandName() {
    const argv1 = process.argv[1] || 'onedrive-cli'
    const rel = Path.relative(process.cwd(), argv1)
    return rel && !rel.startsWith('..') && !Path.isAbsolute(rel)
        ? rel
        : Path.basename(argv1)
}

function buildLoginUrl(readonly, state) {
    const scope = readonly ? 'onedrive.readonly' : 'onedrive.readwrite'
    // state doubles as the CSRF nonce. The loopback flow packs "<nonce>.<port>"
    // in here so the callback page knows which local port to forward the token
    // to; a plain login just uses an unguessable nonce.
    state = state || Crypto.randomBytes(16).toString('hex')
    // Pass our command name to the landing page via a redirect_uri query
    // param so it can show a runnable command.
    const redirect =
        'https://www.lunesu.com/onedrive-cli/oauthcallbackhandler.html?cmd=' +
        encodeURIComponent(commandName())
    return (
        'https://login.live.com/oauth20_authorize.srf?client_id=0000000040197E82&scope=' +
        scope +
        '&response_type=token&state=' +
        encodeURIComponent(state) +
        '&redirect_uri=' +
        encodeURIComponent(redirect)
    )
}

function loginUrl(readonly) {
    console.log('\nBrowse to', Colors.underline(buildLoginUrl(readonly)))
}

// Start a throwaway loopback listener that the callback page forwards the token
// to (see docs/oauthcallbackhandler.html). Resolves { url, wait, cancel }: open
// `url` to sign in, `wait` resolves with the captured token, `cancel` shuts the
// listener down. The token goes browser -> 127.0.0.1 directly, so it never
// passes through stdio or the model.
function loopbackLogin(readonly) {
    const nonce = Crypto.randomBytes(16).toString('hex')
    const server = Http.createServer()
    let settle
    const wait = new Promise(resolve => (settle = resolve))
    server.on('request', (req, res) => {
        const u = new URL(req.url, 'http://127.0.0.1')
        res.setHeader('Access-Control-Allow-Origin', '*')
        if (u.pathname !== '/callback') {
            return res.writeHead(404).end()
        }
        const token = u.searchParams.get('token')
        if (!token || u.searchParams.get('nonce') !== nonce) {
            return res.writeHead(400).end('bad request')
        }
        res.writeHead(200, { 'Content-Type': 'text/plain' })
        res.end('onedrive-cli received the token. You can close this tab.')
        settle(extractToken(token))
    })
    return new Promise((resolve, reject) => {
        server.on('error', reject)
        server.listen(process.env.PORT | 0, '127.0.0.1', () => {
            resolve({
                url: buildLoginUrl(
                    readonly,
                    nonce + '.' + server.address().port
                ),
                wait,
                cancel: () => server.close(),
            })
        })
    })
}

// Best-effort: open the sign-in URL in the user's browser (CLI only).
function openBrowser(url) {
    const opener =
        process.platform === 'darwin'
            ? 'open'
            : process.platform === 'win32'
            ? 'explorer'
            : 'xdg-open'
    try {
        require('child_process')
            .spawn(opener, [url], { stdio: 'ignore', detached: true })
            .on('error', () => {})
            .unref()
    } catch (e) {
        /* best effort */
    }
}

function ask(question) {
    const rl = Readline.createInterface({
        input: process.stdin,
        output: process.stdout,
    })
    return new Promise(resolve => {
        rl.question(question, answer => {
            rl.close()
            resolve(answer)
        })
    })
}

// Accept a bare access token or a whole pasted "<cmd> login <token>" line.
function extractToken(input) {
    input = input.trim()
    const m = /\blogin\s+(?:-r\s+|--readonly\s+)?(.+)$/s.exec(input)
    return (m ? m[1] : input).trim()
}

async function login(args) {
    let loginMessage = 'Access token was saved to '
    let readonly = false
    if (args[0] === '-r' || args[0] === '--readonly') {
        loginMessage = 'Read-Only ' + loginMessage
        readonly = true
        args.shift()
    }
    const arg = args.pop()
    if (typeof arg === 'string') {
        return loginMessage + (await saveToken(arg))
    }

    // No token given: open the browser and capture it via a loopback listener.
    let lb = null
    try {
        lb = await loopbackLogin(readonly)
    } catch (e) {
        // Couldn't bind a local port; fall back to the manual paste prompt.
    }
    if (!lb) {
        loginUrl(readonly)
        const pasted = extractToken(
            await ask('\nPaste the token (or the whole command) here: ')
        )
        if (pasted) {
            return loginMessage + (await saveToken(pasted))
        }
        return console.error('usage: login [-r|--readonly] [access_token]')
    }

    console.log(
        '\nOpening your browser to sign in. If it does not open, visit:'
    )
    console.log(Colors.underline(lb.url))
    openBrowser(lb.url)

    // Accept whichever arrives first: the loopback capture (local browser) or a
    // pasted token (e.g. the browser is on another machine / a dev container).
    const rl = Readline.createInterface({
        input: process.stdin,
        output: process.stdout,
    })
    let pastedWon = false
    const pasted = new Promise(resolve =>
        rl.question(
            '\nWaiting for sign-in, or paste the token here: ',
            answer => {
                pastedWon = true
                resolve(extractToken(answer))
            }
        )
    )
    let token
    try {
        token = await Promise.race([lb.wait, pasted])
    } finally {
        lb.cancel()
        rl.close()
    }
    // A loopback capture leaves the prompt line dangling (no Enter was pressed),
    // so the success message would print right after it. Return to the start of
    // the line (and clear it on a TTY) so the result reads cleanly.
    if (!pastedWon) {
        process.stdout.write('\r' + (process.stdout.isTTY ? '\x1b[K' : ''))
    }
    if (token) {
        return loginMessage + (await saveToken(token))
    }
    console.error('usage: login [-r|--readonly] [access_token]')
}

async function ln(args) {
    if (args.length !== 1) {
        console.error('usage: ln file')
    } else {
        const remote = sanitize(args[0])
        const result = await call(remote + '/action.createLink', 'POST', {
            type: 'view',
        })
        console.log(Colors.underline(result.link.webUrl))
    }
}

const MINUS_W = '-w'
const MINUS_RW = '-rw'

async function chmod1(mode, remote) {
    remote = sanitize(remote)
    const result = await call(remote + '/permissions')
    // +w  x        POST (TODO)
    // +w  read     PATCH (TODO)
    // +w  write    NOP
    // -w  write    PATCH
    // -w  read     NOP
    // -rw write    DELETE
    // -rw read     DELETE
    let ok // FIXME track result from all shares
    for (const cur of result.value) {
        if (mode === MINUS_RW) {
            ok = await call(
                '/drive/root' + remote + ':/permissions/' + cur.id,
                'DELETE'
            )
        } else if (cur.roles[0] === 'write') {
            // FIXME: generic 'edit' links cannot be patched to be read only
            ok = await call(
                '/drive/root' + remote + ':/permissions/' + cur.id,
                'PATCH',
                { roles: ['read'] }
            )
        }
    }
    return ok ? 'OK' : 'Nothing was changed'
}

async function chmod(args) {
    if (args.length < 2) {
        console.error('usage: chmod mode file ...')
    } else {
        let mode = args[0]
        switch (mode) {
            case '0600':
            case '0700':
            case '600':
            case '700':
            case 'g-rw':
            case 'o-rw':
            case 'go-rw':
            case 'og-rw':
            case '-rw':
                mode = MINUS_RW
                break

            case '0644':
            case '0744':
            case '644':
            case '744':
            case 'g-w':
            case 'o-w':
            case 'go-w':
            case 'og-w':
            case '-w':
                mode = MINUS_W
                break

            default:
                console.error('chmod: Invalid file mode:', mode)
                return
        }

        for (const cur of args.slice(1)) {
            await chmod1(mode, cur)
        }
    }
}

async function sendmail1(email, file) {
    const payload = {
        requireSignIn: 'true',
        sendInvitation: 'true',
        roles: ['write'],
        recipients: [{ email: email }],
        // "message": "You were invited by x to access y"
    }
    const remote = sanitize(file)
    const result = await call(remote + '/action.invite', 'POST', payload)
    console.log(JSON.stringify(result, undefined, 2))
}

async function sendmail(args) {
    if (args.length < 2) {
        console.error('usage: sendmail file recipient ...')
    } else {
        const file = args[0]
        for (const cur of args.slice(1)) {
            await sendmail1(cur, file)
        }
    }
}

function getItem(file) {
    const remote = sanitize(file)
    return call(remote)
}

async function stat1(file) {
    const result = await getItem(file)
    console.log(JSON.stringify(result, undefined, 2))
}

async function stat(args) {
    if (args.length === 0) {
        args = ['']
    }
    for (const cur of args) {
        await stat1(cur)
    }
}

async function find_paged(cont, expression) {
    if (cont === undefined) {
        return
    }
    const result = await call(cont)
    result.value
        .filter(info => expression.dirOnly !== !info.folder)
        .filter(info => !expression.regex || expression.regex.test(info.name))
        .map(absolute)
        .forEach(file => {
            if (expression.print0) {
                process.stdout.write(file)
                process.stdout.write('\0')
            } else {
                console.log(file)
            }
        })
    await find_paged(result['@odata.nextLink'], expression)
    // Recurse into subfolders
    const folders = result.value.filter(info => info.folder)
    for (const info of folders) {
        await find_paged(sanitize(absolute(info)) + '/children', expression)
    }
}

function globToRegExp(glob, flags) {
    const regex = glob
        .replace(/([$^|{}().[\]+\\])/g, '\\$1')
        .replace(/\*/g, '.*')
        .replace(/\?/g, '.')
    return new RegExp('^' + regex + '$', flags)
}

async function find(args) {
    if (args.length === 0) {
        console.error(
            'usage: find path ... [-print0] [-name GLOB] [-iname GLOB] [-regex REGEX] [-iregex REGEX] [-type d|f]'
        )
    } else {
        const expression = {}
        for (let index = 0; index < args.length; ) {
            switch (args[index]) {
                case '-print0':
                    expression.print0 = args.splice(index, 1)
                    break
                case '-type':
                    // This is used as a tri-state: true, false, undefined
                    expression.dirOnly = args.splice(index, 2)[1] === 'd'
                    break
                case '-name':
                    expression.regex = globToRegExp(args.splice(index, 2)[1])
                    break
                case '-iname':
                    expression.regex = globToRegExp(
                        args.splice(index, 2)[1],
                        'i'
                    )
                    break
                case '-regex':
                    expression.regex = new RegExp(args.splice(index, 2)[1])
                    break
                case '-iregex':
                    expression.regex = new RegExp(args.splice(index, 2)[1], 'i')
                    break
                default:
                    index++
            }
        }
        for (const folder of args) {
            await find_paged(sanitize(folder) + '/children', expression)
        }
    }
}

/*
GET /drive/root/view.search?q={query}
Server-side full-text search across the whole drive, listing the paths of
matching files (like `grep -rl`). OneDrive pages the matches for us. The API
ignores any folder anchor, so the search is always global -- pipe to e.g.
`grep '^:/folder/'` to limit it to a subtree, or use `find -iname` to match
on filenames instead of contents.
*/
async function grep_paged(cont) {
    if (cont === undefined) {
        return
    }
    const result = await call(cont)
    result.value.map(absolute).forEach(file => console.log(file))
    await grep_paged(result['@odata.nextLink'])
}

async function grep(args) {
    if (args.length !== 1) {
        console.error(
            'usage: grep pattern   (full-text; use `find -iname` for filenames)'
        )
    } else {
        const query = encodeURIComponent(args[0])
        await grep_paged('/drive/root/view.search?q=' + query)
    }
}

// --- MCP (Model Context Protocol) server -----------------------------------
// A read-only stdio MCP server, mirroring github.com/lionello/gdrive-mcp but
// for OneDrive. It reuses the low-level helpers above (call, getContent,
// sanitize, absolute) and only ever issues GET requests, so it cannot mutate
// the drive. Note: nothing here may write to stdout -- that is the JSON-RPC
// channel. The helpers only log to stderr, and only when stdout is a TTY
// (which it is not under MCP), so they stay silent.

// Structured equivalents of ls/grep/find that return data instead of printing.
async function listFolder(path) {
    const items = []
    let cont = sanitize(path) + '/children'
    while (cont) {
        const result = await call(cont)
        for (const f of result.value) {
            items.push({
                name: f.name,
                path: absolute(f),
                type: is_folder(f) ? 'folder' : 'file',
                size: f.size,
                lastModified: f.lastModifiedDateTime,
                ...(f.folder ? { childCount: f.folder.childCount } : {}),
            })
        }
        cont = result['@odata.nextLink']
    }
    return items
}

async function searchContent(query) {
    const paths = []
    let cont = '/drive/root/view.search?q=' + encodeURIComponent(query)
    while (cont) {
        const result = await call(cont)
        for (const f of result.value) {
            paths.push(absolute(f))
        }
        cont = result['@odata.nextLink']
    }
    return paths
}

async function findItems(path, expression, acc = []) {
    let cont = sanitize(path) + '/children'
    while (cont) {
        const result = await call(cont)
        for (const info of result.value) {
            const matchesType =
                expression.dirOnly === undefined ||
                expression.dirOnly === !!info.folder
            const matchesName =
                !expression.regex || expression.regex.test(info.name)
            if (matchesType && matchesName) {
                acc.push(absolute(info))
            }
        }
        // Recurse into subfolders found on this page.
        for (const info of result.value.filter(i => i.folder)) {
            await findItems(absolute(info), expression, acc)
        }
        cont = result['@odata.nextLink']
    }
    return acc
}

async function mcp() {
    const { McpServer } = require('@modelcontextprotocol/sdk/server/mcp.js')
    const {
        StdioServerTransport,
    } = require('@modelcontextprotocol/sdk/server/stdio.js')
    const { z } = require('zod')
    const { version } = require('../package.json')

    const server = new McpServer({ name: 'onedrive-cli', version })

    const asJson = data => ({
        content: [{ type: 'text', text: JSON.stringify(data, undefined, 2) }],
    })

    // Turn an auth/permission failure into an actionable login hint instead of a
    // bare API error, so the agent knows to (re-)authenticate via login_onedrive.
    const authHint = err => {
        if (err.path === TOKEN_PATH || err.code === 'ENOENT') {
            return 'Not logged in to OneDrive. Call login_onedrive to sign in, then retry.'
        }
        if (err.statusCode === 401 || err.code === 'unauthenticated') {
            return 'The OneDrive access token is missing or expired. Call login_onedrive to sign in again, then retry.'
        }
        if (err.statusCode === 403) {
            return 'Access denied -- the saved token may be read-only. Call login_onedrive with readonly:false for read-write access, then retry.'
        }
        return null
    }

    // registerTool wrapper: run the handler, but map auth errors to a login hint.
    const rawRegister = server.registerTool.bind(server)
    const register = (name, def, handler) =>
        rawRegister(name, def, async args => {
            try {
                return await handler(args)
            } catch (err) {
                const hint = authHint(err)
                if (hint)
                    return asJson({
                        ok: false,
                        needsLogin: true,
                        message: hint,
                    })
                throw err
            }
        })

    register(
        'list_onedrive_folder',
        {
            title: 'List OneDrive folder',
            description:
                'List the direct children (files and folders) of a OneDrive folder. Pass an empty string to list the drive root.',
            inputSchema: {
                path: z
                    .string()
                    .default('')
                    .describe(
                        "Remote folder path, e.g. 'Documents/Reports'. Empty string for the drive root."
                    ),
            },
        },
        async ({ path }) => asJson(await listFolder(path || ''))
    )

    register(
        'search_onedrive_content',
        {
            title: 'Search OneDrive (full-text)',
            description:
                'Full-text search across the whole drive (matches file names and contents). Returns the paths of matching items, like `grep -rl`.',
            inputSchema: {
                query: z.string().describe('The search query.'),
            },
        },
        async ({ query }) => asJson(await searchContent(query))
    )

    register(
        'find_onedrive_files',
        {
            title: 'Find OneDrive files by name',
            description:
                'Recursively find items by name under a folder, using a shell glob pattern (e.g. "*.pdf"). Optionally restrict to files or folders.',
            inputSchema: {
                path: z
                    .string()
                    .default('')
                    .describe(
                        'Folder to search under. Empty string for the drive root.'
                    ),
                name: z
                    .string()
                    .optional()
                    .describe(
                        'Case-insensitive glob matched against item names, e.g. "*.docx". Omit to match everything.'
                    ),
                type: z
                    .enum(['file', 'folder'])
                    .optional()
                    .describe('Restrict results to files or folders.'),
            },
        },
        async ({ path, name, type }) => {
            const expression = {}
            if (name) {
                expression.regex = globToRegExp(name, 'i')
            }
            if (type) {
                expression.dirOnly = type === 'folder'
            }
            return asJson(await findItems(path || '', expression))
        }
    )

    register(
        'read_onedrive_file',
        {
            title: 'Read OneDrive file',
            description:
                'Read a byte range of a file via an HTTP Range request, so only the requested bytes are downloaded (scales to large files). Returns the bytes decoded as UTF-8 plus totalBytes and hasMore so you can page. A range may split a line or a multi-byte UTF-8 character at either boundary. Binary files will be garbled.',
            inputSchema: {
                path: z
                    .string()
                    .describe("Remote file path, e.g. 'Documents/notes.txt'."),
                offset: z
                    .number()
                    .int()
                    .min(0)
                    .default(0)
                    .describe('Byte offset to start reading from.'),
                length: z
                    .number()
                    .int()
                    .min(1)
                    .max(1048576)
                    .default(65536)
                    .describe('Number of bytes to read (max 1 MiB).'),
            },
        },
        async ({ path, offset, length }) => {
            const { buffer, total } = await getRange(
                sanitize(path) + '/content',
                offset,
                length
            )
            return asJson({
                path,
                offset,
                bytesReturned: buffer.length,
                totalBytes: total,
                hasMore: total !== undefined && offset + buffer.length < total,
                content: buffer.toString('utf8'),
            })
        }
    )

    register(
        'stat_onedrive_item',
        {
            title: 'Stat OneDrive item',
            description: 'Return the full metadata for a file or folder.',
            inputSchema: {
                path: z
                    .string()
                    .default('')
                    .describe('Remote path. Empty string for the drive root.'),
            },
        },
        async ({ path }) => asJson(await getItem(path || ''))
    )

    register(
        'onedrive_storage',
        {
            title: 'OneDrive storage quota',
            description:
                'Report the storage quota (total, used, remaining) for the available drives.',
            inputSchema: {},
        },
        async () => {
            const result = await call('/drives')
            return asJson(
                result.value.map(d => ({
                    id: d.id,
                    status: d.status ? d.status.state : null,
                    quota: d.quota,
                }))
            )
        }
    )

    register(
        'login_onedrive',
        {
            title: 'Log in to OneDrive',
            description:
                'Authenticate to OneDrive when calls fail with an authentication error. Presents a sign-in link out-of-band and captures the token locally via a loopback listener -- nothing sensitive passes through this conversation. If the link cannot be presented or the listener is unreachable (e.g. a dev container), it returns loginUrl; open it, sign in, then call this tool again with the token shown on the page.',
            inputSchema: {
                token: z
                    .string()
                    .optional()
                    .describe(
                        'Fallback: an access token copied from the callback page, saved directly. Omit to start the interactive sign-in.'
                    ),
                readonly: z
                    .boolean()
                    .default(true)
                    .describe(
                        'Request read-only access (onedrive.readonly). Defaults to true since this MCP server only reads; set false to grant read-write.'
                    ),
            },
        },
        async ({ token, readonly }) => {
            if (token) {
                await saveToken(extractToken(token))
                return asJson({ ok: true, message: 'Access token saved.' })
            }
            let lb = null
            try {
                lb = await loopbackLogin(readonly)
            } catch (e) {
                // Couldn't bind a local port; fall through to the paste path.
            }
            const url = lb ? lb.url : buildLoginUrl(readonly)

            // Only present the link via URL-mode elicitation if the client
            // actually advertises support -- attempting it otherwise makes the
            // client surface an "unsupported" error. When supported, wait for
            // the loopback to catch the token and finish here.
            const caps = server.server.getClientCapabilities()
            const canUrlElicit = !!(
                caps &&
                caps.elicitation &&
                caps.elicitation.url
            )
            if (canUrlElicit && lb) {
                try {
                    const result = await server.server.elicitInput({
                        mode: 'url',
                        message:
                            'Sign in to OneDrive in your browser to authorize this server. The token is captured locally; nothing is pasted here.',
                        url,
                        elicitationId: Crypto.randomBytes(8).toString('hex'),
                    })
                    if (result.action !== 'accept') {
                        lb.cancel()
                        return asJson({
                            ok: false,
                            action: result.action,
                            message: 'Login was ' + result.action + '.',
                        })
                    }
                    const captured = await withTimeout(lb.wait, 120000)
                    await saveToken(captured)
                    lb.cancel()
                    return asJson({ ok: true, message: 'Access token saved.' })
                } catch (err) {
                    // Presented, but the token didn't arrive in time.
                    lb.cancel()
                    return asJson({
                        ok: false,
                        loginUrl: url,
                        message:
                            'Did not receive the token automatically (expected in dev containers, where the browser cannot reach this server). Open loginUrl, sign in, then call login_onedrive again with the token from the page.',
                    })
                }
            }

            // No URL-mode elicitation (or no loopback): this is NOT an error --
            // return the sign-in URL for the agent to hand to the user. Keep the
            // loopback listening so the token is captured and saved out-of-band
            // when the user opens the link (every request re-reads the token
            // file, so a subsequent call just works).
            if (lb) {
                lb.wait.then(saveToken, () => {}).finally(() => lb.cancel())
                setTimeout(() => lb.cancel(), 5 * 60 * 1000).unref()
                return asJson({
                    ok: false,
                    pending: true,
                    loginUrl: url,
                    message:
                        'Ask the user to open loginUrl in a browser and sign in. If the browser is on this machine, the token is captured and saved automatically -- then just retry the request. In a dev container (browser elsewhere), have the user copy the token shown on the page and call login_onedrive again with it in the token argument.',
                })
            }
            return asJson({
                ok: false,
                loginUrl: url,
                message:
                    'Ask the user to open loginUrl and sign in, then call login_onedrive again with the token shown on the page.',
            })
        }
    )

    const transport = new StdioServerTransport()
    await server.connect(transport)
}

async function main(argv) {
    // Disable colors when piping to another command
    if (!process.env.FORCE_COLOR && !process.stdout.isTTY) {
        Colors.disable()
    }

    switch (argv[2]) {
        case undefined:
        case 'help':
            console.log(
                Colors.bold(
                    '\nOneDrive Command Line Interface (c) Lionello Lunesu'
                )
            )
            console.log(
                '\nusage: onedrive COMMAND [arguments]\n\ncommands: cat chmod cp df find grep help ln login ls mcp mkdir mv rm sendmail stat wget'
            )
            return

        case 'cat':
            return cat(argv.slice(3))

        case 'chmod':
            return chmod(argv.slice(3))

        case 'cp':
            return cp(argv.slice(3))

        case 'df':
            return df()

        case 'find':
            return find(argv.slice(3))

        case 'grep':
            return grep(argv.slice(3))

        case 'ln':
            return ln(argv.slice(3))

        case 'login':
            return login(argv.slice(3))

        case 'ls':
            return ls(argv.slice(3))

        case 'mcp':
            return mcp()

        case 'mkdir':
            return mkdir(argv.slice(3))

        case 'mv':
            return mv(argv.slice(3))

        case 'rm':
            return rm(argv.slice(3))

        case 'sendmail':
            return sendmail(argv.slice(3))

        case 'stat':
            return stat(argv.slice(3))

        case 'wget':
            return wget(argv.slice(3))

        default:
            throw Error('Unknown command: ' + argv[2])
    }
}

main(process.argv).then(
    result => {
        if (result !== undefined) {
            console.log(Colors.green(result))
        }
    },
    err => {
        console.error(Colors.red(err.localizedMessage || err.message))
        debugPrint(err)
        // Auth failures: guide the user to re-authenticate. Exit -1 so xargs stops.
        if (err.path === TOKEN_PATH || err.code === 'ENOENT') {
            console.error("You're not logged in.")
            loginUrl()
            process.exitCode = -1
        } else if (err.statusCode === 401 || err.code === 'unauthenticated') {
            console.error(
                'Your access token is invalid or expired. Log in again:'
            )
            loginUrl()
            process.exitCode = -1
        } else if (err.statusCode === 403) {
            console.error(
                'Access denied -- your saved token may be read-only. Log in again for read-write access:'
            )
            loginUrl(false)
            process.exitCode = -1
        } else {
            process.exitCode = 1
        }
    }
)

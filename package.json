{
    "name": "@lionello/onedrive-cli",
    "version": "1.3.0",
    "description": "OneDrive CLI",
    "bin": {
        "onedrive-cli": "bin/onedrive"
    },
    "scripts": {
        "format": "prettier -w bin/onedrive docs/oauthcallbackhandler.html",
        "lint": "npx eslint bin/onedrive",
        "readme": "cat docs/_header.html > docs/index.html && redcarpet --parse fenced-code-blocks --parse tables --parse autolink --parse strikethrough README.md >> docs/index.html && cat docs/_footer.html >> docs/index.html",
        "preversion": "npm run lint",
        "release:patch": "npm version patch && git push --follow-tags",
        "release:minor": "npm version minor && git push --follow-tags",
        "release:major": "npm version major && git push --follow-tags"
    },
    "keywords": [
        "onedrive",
        "skydrive",
        "cli",
        "upload",
        "download"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lionello/onedrive-cli.git"
    },
    "engines": {
        "node": ">=18"
    },
    "author": "Lionello Lunesu",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "colors": "^1.4.0",
        "mime": "^1.6.0",
        "moment": "^2.30.1",
        "node-fetch": "^2.7.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "prettier": "^2.8.8"
    },
    "prettier": {
        "semi": false,
        "singleQuote": true,
        "arrowParens": "avoid"
    }
}

{
    "name": "@lionello/onedrive-cli",
    "version": "1.2.0",
    "description": "OneDrive CLI",
    "bin": {
        "onedrive-cli": "bin/onedrive"
    },
    "scripts": {
        "format": "prettier -w --single-quote bin/onedrive",
        "lint": "npx eslint bin/onedrive",
        "readme": "cat docs/_header.html > docs/index.html && redcarpet --parse fenced-code-blocks --parse tables --parse autolink --parse strikethrough README.md >> docs/index.html && cat docs/_footer.html >> docs/index.html"
    },
    "keywords": [
        "onedrive",
        "skydrive",
        "cli",
        "upload",
        "download"
    ],
    "repository": {
        "type": "git",
        "url": "git@github.com:lionello/onedrive-cli.git"
    },
    "engines": {
        "node": ">=18"
    },
    "author": "Lionello Lunesu",
    "license": "MIT",
    "dependencies": {
        "colors": "^1.4.0",
        "mime": "^1.6.0",
        "moment": "^2.30.1",
        "node-fetch": "^2.7.0"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "prettier": "^2.8.8"
    },
    "prettier": {
        "semi": false,
        "arrowParens": "avoid"
    }
}
